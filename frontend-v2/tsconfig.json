{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./src",
    "paths": {
      "@components/*": ["components/*"],
      "@context/*": ["context/*"],
      "@data/*": ["data/*"],
      "@navigation/*": ["navigation/*"],
      "@screens/*": ["screens/*"],
      "@services/*": ["services/*"],
      "@theme/*": ["theme/*"],
      "@app-types/*": ["types/*"]
    }
  },
  "include": ["src", "App.tsx", "index.ts"]
}
